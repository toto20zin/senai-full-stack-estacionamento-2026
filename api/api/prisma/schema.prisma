generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}


model automovel {
  placa        String  @id
  proprietario String
  modelo       String
  tipo         String
  marca        String
  cor          String?
  ano          Int?
  telefone     String?

  estadias estadia[]
}

model estadia {
  id         Int      @id @default(autoincrement())
  placa      String
  entrada    DateTime @default(now())
  saida      DateTime?
  valorHora  Float
  valorTotal Float?

  veiculo    automovel @relation(fields: [placa], references: [placa])
}

