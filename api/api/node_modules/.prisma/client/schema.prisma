generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Automovel {
  placa        String        @id
  proprietario String
  tipo         TipoAutomovel
  modelo       String
  marca        String
  cor          String?
  ano          Int?
  telefone     String?

  estadias Estadia[]
}

model Estadia {
  id         Int       @id @default(autoincrement())
  placa      String
  entrada    DateTime  @default(now())
  saida      DateTime?
  valorHora  Decimal
  valorTotal Decimal?

  automovel Automovel @relation(fields: [placa], references: [placa])
}

enum TipoAutomovel {
  CARRO
  MOTO
  VAN
  CAMINHAO
  ONIBUS
}
